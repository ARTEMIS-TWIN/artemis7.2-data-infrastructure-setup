                     <type>rdfs:Literal</type>
                     <instance_generator name="Literal">
                        <arg name="text" type="xpath">text()</arg>
                     </instance_generator>
                  </entity>
               </target_node>
            </range>
         </link>
         <link>
            <path>
               <source_relation>
                  <relation>operations/operation</relation>
               </source_relation>
               <target_relation>
                  <relationship>crm:P9_consists_of</relationship>
               </target_relation>
            </path>
            <range>
               <source_node>operations/operation</source_node>
               <target_node>
                  <entity>
                     <type>crm:E7_Activity</type>
                     <instance_generator name="LocalTermURI">
                        <arg name="hierarchy" type="xpath">//pilot_id/text()</arg>
                        <arg name="term" type="xpath">operation_id/text()</arg>
                     </instance_generator>
                     <label_generator name="Literal">
                        <arg name="text" type="xpath">concat(ancestor::artemis_pilot/pilot_id, ' ', operation_id, ' ', operation_title)</arg>
                     </label_generator>
                  </entity>
               </target_node>
            </range>
         </link>
