               </target_node>
            </range>
         </link>
         <link>
            <path>
               <source_relation>
                  <relation>used_devices/device</relation>
               </source_relation>
               <target_relation>
                  <if>
                     <equals value="Sensor">device_type</equals>
                  </if>
                  <relationship>crm:P16_used_specific_object</relationship>
               </target_relation>
            </path>
            <range>
               <source_node>used_devices/device</source_node>
               <target_node>
                  <entity>
                     <type>rhdto:HC9_Sensor</type>
                     <instance_generator name="UUID"/>
                     <label_generator name="CompositeLabel">
                        <arg name="term1" type="xpath">device_label/text()</arg>
                        <arg name="term2" type="xpath">device_identifier/text()</arg>
                     </label_generator>
                  </entity>
               </target_node>
            </range>
         </link>
         <link>
            <path>
               <source_relation>
                  <relation>used_devices/device</relation>
               </source_relation>
               <target_relation>
                  <if>
                     <equals value="Node">device_type</equals>
                  </if>
                  <relationship>crm:P16_used_specific_object</relationship>
               </target_relation>
            </path>
            <range>
               <source_node>used_devices/device</source_node>
               <target_node>
                  <entity>
                     <type>rhdto:HC25_Node</type>
                     <instance_generator name="UUID"/>
                     <label_generator name="CompositeLabel">
                        <arg name="term1" type="xpath">device_label/text()</arg>
                        <arg name="term2" type="xpath">device_identifier/text()</arg>
                     </label_generator>
                  </entity>
               </target_node>
            </range>
         </link>
         <link>
            <path>
               <source_relation>
                  <relation>used_devices/device</relation>
               </source_relation>
               <target_relation>
                  <if>
                     <and>
                        <if>
                           <not>
                              <if>
                                 <equals value="Sensor">device_type</equals>
                              </if>
                           </not>
                        </if>
                        <if>
                           <not>
                              <if>
                                 <equals value="Node">device_type</equals>
                              </if>
                           </not>
                        </if>
                     </and>
                  </if>
                  <relationship>crm:P16_used_specific_object</relationship>
               </target_relation>
            </path>
            <range>
               <source_node>used_devices/device</source_node>
               <target_node>
                  <entity>
                     <type>crmdig:D8_Digital_Device</type>
                     <instance_generator name="UUID"/>
                     <label_generator name="Literal">
                        <arg name="text" type="xpath">device_label/text()</arg>
                        <arg name="language" type="xpath">device_identifier/text()</arg>
                     </label_generator>
                  </entity>
               </target_node>
            </range>
         </link>
         <link>
            <path>
               <source_relation>
                  <relation>time_span</relation>
               </source_relation>
               <target_relation>
