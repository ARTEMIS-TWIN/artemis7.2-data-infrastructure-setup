   <mappings>
      <mapping>
         <domain>
            <source_node>/artemis_pilot</source_node>
            <target_node>
               <entity>
                  <type>crm:E7_Activity</type>
                  <instance_generator name="LocalTermURI">
                     <arg name="hierarchy" type="constant">pilots</arg>
                     <arg name="term" type="xpath">pilot_id/text()</arg>
                  </instance_generator>
                  <label_generator name="Literal">
                     <arg name="text" type="xpath">pilot_title/text()</arg>
                  </label_generator>
               </entity>
            </target_node>
            <comments>
               <comment type="">
                  <rationale>PILOT</rationale>
                  <alternatives/>
                  <typical_mistakes/>
                  <local_habits/>
                  <link_to_cook_book/>
                  <example>
                     <example_source/>
                     <example_target/>
                  </example>
                  <comments_last_update date="2026-04-29 09:44:52" person="Laura Tonti"/>
               </comment>
            </comments>
         </domain>
         <link>
            <path>
               <source_relation>
                  <relation>pilot_id</relation>
               </source_relation>
               <target_relation>
                  <relationship>crm:P1_is_identified_by</relationship>
               </target_relation>
            </path>
            <range>
               <source_node>pilot_id</source_node>
               <target_node>
                  <entity>
                     <type>crm:E42_Identifier</type>
                     <instance_generator name="UUID"/>
                     <label_generator name="Literal">
                        <arg name="text" type="xpath">text()</arg>
                     </label_generator>
                  </entity>
               </target_node>
            </range>
         </link>
         <link>
            <path>
               <source_relation>
                  <relation>pilot_title</relation>
               </source_relation>
               <target_relation>
