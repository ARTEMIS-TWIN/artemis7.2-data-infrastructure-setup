                     <instance_generator name="UUID"/>
                     <label_generator name="Literal">
                        <arg name="text" type="xpath">concat(ancestor::artemis_pilot/pilot_title, ', ', ancestor::operation/operation_id, ', parameter ', parameter_set_label)</arg>
                     </label_generator>
