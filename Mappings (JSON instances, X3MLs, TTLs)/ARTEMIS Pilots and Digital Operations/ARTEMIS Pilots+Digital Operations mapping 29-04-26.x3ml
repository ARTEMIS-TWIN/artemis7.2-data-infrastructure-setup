                           </instance_generator>
                        </entity>
                     </additional>
                     <additional>
                        <relationship>crm:P80_end_is_qualified_by</relationship>
                        <entity>
                           <type>rdfs:Literal</type>
                           <instance_generator name="Literal">
                              <arg name="text" type="xpath">end/text()</arg>
                           </instance_generator>
                        </entity>
                     </additional>
                  </entity>
               </target_node>
            </range>
         </link>
         <link>
            <path>
