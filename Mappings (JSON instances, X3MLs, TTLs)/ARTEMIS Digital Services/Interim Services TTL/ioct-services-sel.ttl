        rdfs:label                    "IoCT Services (SEL)" ;
        rhdto:HP30_provided_by        <urn:uuid:d40ec813-a080-4b26-899e-cc118bb686af> ;
        crm:P102_has_title            <urn:uuid:4f990e91-9a84-4e7f-b6b6-a53fd3711c06> ;
        crm:P125_used_object_of_type  "Arduino Nano 33 IoT" , "Solar Panel" , "Ground Movement Sensor" , "SEL-designed IoT Node (120x80x75 mm)" , "Light Sensor" , "Microvegetation Sensor" , "Third-party Temperature/Humidity Sensors" ;
        crm:P16i_was_used_for         <urn:uuid:9b5b0ce8-530f-452e-80d9-b22ddf47d3b5> , <urn:uuid:f09c43a4-960c-43af-aa63-615f21419212> ;
        crm:P2_has_type               <urn:uuid:fe6f8bbd-3684-44de-8780-1f9ed9dd087d> ;
        crm:P3_has_note               "IoT service based on custom IoT nodes designed and developed by SEL, housed in 120x80x75 mm enclosures. Uses an Arduino Nano 33 IoT microprocessor connected to third-party environmental sensors (temperature, humidity, light, ground movements, microvegetation). Node autonomy via solar-panel power supply. Data transmitted to ARTEMIS cloud infrastructure using RESTful services (ARTEMIS IoT Microservices) and MQTT protocol, stored in a dedicated NoSQL database." ;
        aocat:has_functionality       <urn:uuid:b3dc9910-f4a3-4241-aacf-b4c695341b9d> , <urn:uuid:3933a981-6489-4471-9da4-af488dd89cd9> , <urn:uuid:68f575dc-e9ff-4c3c-ba75-0cf3267b7b11> , <urn:uuid:fe6f8bbd-3684-44de-8780-1f9ed9dd087d> ;
