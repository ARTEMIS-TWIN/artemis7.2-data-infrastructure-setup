<https://artemis-twin.eu/entity/service//algorithmic-mesh-reconstruction-odr>
        a                         rhdto:HC21_Digital_Service ;
        rdfs:label                "Algorithmic Mesh Reconstruction based on Offence-Defence Ratio" ;
        rhdto:HP30_provided_by    <urn:uuid:7a570ea9-8df2-4402-8516-bed965cd6eb3> ;
        crm:P102_has_title        <urn:uuid:18685f3f-fcf9-4374-8513-0b15375d28cd> ;
        crm:P16i_was_used_for     <urn:uuid:30d4d1d1-013f-42dd-99cf-750fec2ef6fd> ;
        crm:P2_has_type           <urn:uuid:d6657645-94a4-4b00-92bb-d27b1af67bd3> ;
        crm:P3_has_note           "Algorithm generating defence-offence ratios from three data sources: (1) initial 3D mesh dataset following guidelines that expose geometric properties such as openings; (2) user-specified artillery type; (3) landscape and surrounding area data. Data preparation: mesh cleaning/optimisation, semantic segmentation and labelling (walls, openings, parapets, floors, towers), encoding semantics via mesh names, vertex colours, sub-mesh indices and custom JSON metadata aligned with the ARTEMIS ontology. Unity-side ingestion and cloud dispatch via REST API." ;
        aocat:has_consumed_media  "application/json" ;
        aocat:has_functionality   <urn:uuid:d7f55195-6e6d-4d45-a84c-14b07af7810d> , <urn:uuid:86cc24d8-8215-4ff6-b301-6ad9f5f8d804> , <urn:uuid:d6657645-94a4-4b00-92bb-d27b1af67bd3> , <urn:uuid:443ef120-a862-44f9-b1a3-d5fec8ff1572> , <urn:uuid:53d9cd2f-8a9c-4d01-9d82-4a04eee34122> ;
        aocat:has_produced_media  "application/json" .

