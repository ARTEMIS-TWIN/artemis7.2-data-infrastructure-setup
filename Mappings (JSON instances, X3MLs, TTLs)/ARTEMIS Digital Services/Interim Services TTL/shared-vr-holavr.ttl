        a                             rhdto:HC21_Digital_Service ;
        rdfs:label                    "Shared VR (HOLAVR)" ;
        rhdto:HP30_provided_by        <urn:uuid:0f0c254c-cee9-4f97-81f6-817838c08b4a> ;
        crm:P102_has_title            <urn:uuid:81166dad-54d7-4969-8d83-41e21546c313> ;
        crm:P125_used_object_of_type  "360° Chroma Environment" , "Coordinating Computer" , "High-capacity i9 Computer" , "DHCP Server Router" , "Adapted VR Glasses" ;
        crm:P16i_was_used_for         <urn:uuid:db67865b-821b-481f-96f8-806dd00831e7> , <urn:uuid:a93ce605-c5dc-4e12-85ad-958856912715> ;
        crm:P2_has_type               <urn:uuid:2eabd235-bc11-4e1d-a536-2815b692e108> ;
        crm:P3_has_note               "Shared VR visualisation service using adapted VR glasses inside a 360° chroma environment, producing an overlay of virtual 360° images and real-life images. Places users in a fully contextualised collaborative situation for interacting with heritage assets. Functions as main viewer in several pilots with support for multiple viewpoints and intuitive navigation. All VR glasses connect to a high-capacity i9 computer, with a coordinating computer providing monitoring of streaming state, access to the virtual environment database, diagnostics and system control. External service connected to the ARTEMIS infrastructure via standardised APIs." ;
        aocat:has_functionality       <urn:uuid:bd986385-7310-4dab-a749-b87531b8f708> , <urn:uuid:e9615549-a063-4d3e-ac28-3350132a025e> , <urn:uuid:2eabd235-bc11-4e1d-a536-2815b692e108> , <urn:uuid:cd8783ca-c559-4822-8bc2-84e5616cfaf5> , <urn:uuid:6bc7b8ac-ae2a-4fca-804e-c3c275296475> .

<urn:uuid:cd8783ca-c559-4822-8bc2-84e5616cfaf5>
