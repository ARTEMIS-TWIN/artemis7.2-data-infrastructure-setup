        a                             rhdto:HC21_Digital_Service ;
        rdfs:label                    "IoCT Services (LNEC) — DB-HERITAGE Integration" ;
        rhdto:HP30_provided_by        <urn:uuid:44961017-1aa2-4be9-9da1-c36ff27ae582> ;
        crm:P102_has_title            <urn:uuid:ce94fd39-01a0-4d41-8834-95197dbbc647> ;
        crm:P106_is_composed_of       "PostgreSQL Database" , "Django OAuth Toolkit" , "Django Backend" , "DB-HERITAGE (LNEC's CH data management system)" ;
        crm:P125_used_object_of_type  "Wind Speed Sensor" , "Crack Meter" , "Meteorological Station" , "Relative Humidity Sensor" , "Resistivity Sensor" , "Temperature Sensor" ;
        crm:P16i_was_used_for         <urn:uuid:cc8c9936-41de-46ee-929c-d46999d0e543> ;
        crm:P2_has_type               <urn:uuid:d630ecb4-f028-4799-96dd-8f7979446012> ;
        crm:P3_has_note               "ARTEMIS IoCT and DB-HERITAGE (LNEC's CH data management system) data microservices enabling real-time collection and automated pre-processing of data from a network of structural, environmental and conservation sensors installed on instrumented sections of a defensive wall. Supports custom-made and off-the-shelf sensors (temperature, humidity, wind speed, crack meter, resistivity sensors) and meteorological stations. ARTEMIS IoCT microservices (Node Presentation & Registration, Sensor Data Transmission) communicate with the LNEC system API via RESTful and MQTT protocols." ;
