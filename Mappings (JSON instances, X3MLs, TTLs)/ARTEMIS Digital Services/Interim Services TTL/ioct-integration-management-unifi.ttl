<https://artemis-twin.eu/entity/service//ioct-integration-management-unifi>
        a                             rhdto:HC21_Digital_Service ;
        rdfs:label                    "IoCT Integration & Management of Monitoring Data Service (UNIFI)" ;
        rhdto:HP30_provided_by        <urn:uuid:96ab2578-be47-418a-9028-7864cadca1fb> ;
        crm:P102_has_title            <urn:uuid:ad2d21b1-a872-4e19-b5f2-f26a0d6f1576> ;
        crm:P125_used_object_of_type  "Groundwater Piezometer" , "Potentiometer" , "LVDT" , "Accelerometer" , "Temperature/Humidity Sensor" ;
        crm:P16i_was_used_for         <urn:uuid:364bfdd7-9f69-4d8d-a6db-d1efdf0643c1> ;
        crm:P2_has_type               <urn:uuid:bc446e56-d529-44e4-8383-d63e8afde017> ;
        crm:P3_has_note               "Comprehensive suite of RESTful microservices for managing, querying and visualising IoCT sensor data within Digital Twin environments, developed under ARTEMIS WP9 Task 9.1. Handles historical and experimentally collected data, including monitoring data (accelerometers, potentiometers, temperature/humidity, groundwater piezometer) and derived datasets from structural tests and 3D documentation (crack maps, orthophotos, FEM mesh regions). Core functionalities: Node Presentation & Registration, Data Services (scalar and vector time-series), Decision Rules (threshold triggers), Media Handling, Secure Access & Authentication (MQTT token exchange, REST API)." ;
        aocat:has_functionality       <urn:uuid:c526e726-d155-45a1-b729-0be976a7901a> , <urn:uuid:3c48eba7-2ce1-4657-9283-09ef0394b29c> , <urn:uuid:a1c7849b-9251-4c70-9162-97d044379ac3> , <urn:uuid:0180b9f7-eb71-440f-aae0-df13d5b4123e> , <urn:uuid:0acab211-1cc8-4403-a7d1-e95b0dfc257f> , <urn:uuid:ae39096b-bd14-4429-826e-9f30e5faff37> , <urn:uuid:bc446e56-d529-44e4-8383-d63e8afde017> , <urn:uuid:7d44e3b2-5cf4-405e-a076-61f23fa4d8ad> .

