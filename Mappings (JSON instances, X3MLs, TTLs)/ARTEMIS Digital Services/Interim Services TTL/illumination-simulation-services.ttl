        a                         rhdto:HC21_Digital_Service ;
        rdfs:label                "ARTEMIS Illumination Simulation Services" ;
        rhdto:HP30_provided_by    <urn:uuid:a5847628-f0b5-4b07-b99e-bc53d6e06c1e> ;
        crm:P102_has_title        <urn:uuid:f77a2c29-b1a8-4f5e-a0e0-941697cf95f6> ;
        crm:P16i_was_used_for     <urn:uuid:3caeede5-f203-439c-9796-7cbce4612eaa> , <urn:uuid:90ffb422-47cf-46af-9bae-a5b0a91fd955> ;
        crm:P2_has_type           <urn:uuid:80ec3236-6af6-489e-bcd1-694048d01acc> ;
        crm:P3_has_note           "Microservices architecture providing backend infrastructure for physically-based lighting computation on virtual sensors placed in an RHDT 3D environment. Depends on remote rendering services for illumination calculation, scene management and illumination environment definition (sky luminance, luminaires, etc.). Provides interactive estimation of physically-based directional luminance and illuminance using state-of-the-art global illumination methods. Supports multiple sensor types (point, disk, quadrilateral) with photometric measurement readout compatible with physical sensor output. Standardised REST endpoints." ;
        aocat:has_consumed_media  "application/json" ;
        aocat:has_functionality   <urn:uuid:f4f79e87-a6f3-4bd8-bf7b-d5081c1ff360> , <urn:uuid:193fa43f-1d24-4d32-9bf3-20cc728f364b> , <urn:uuid:d85f41b6-d9c2-4157-bb72-65ef77c31f9b> , <urn:uuid:80ec3236-6af6-489e-bcd1-694048d01acc> , <urn:uuid:59cb74a2-7a35-43a5-babf-bc3a872cc4de> , <urn:uuid:5c3e4572-cef6-4a31-8220-f3da59dafe34> , <urn:uuid:84326943-e672-41ff-ab0c-afc12745d7be> ;
        aocat:has_produced_media  "application/json" .

