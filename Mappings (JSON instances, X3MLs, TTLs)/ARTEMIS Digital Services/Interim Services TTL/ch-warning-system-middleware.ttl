<https://artemis-twin.eu/entity/service//ch-warning-system-middleware>
        a                         rhdto:HC21_Digital_Service ;
        rdfs:label                "CH Warning System Middleware (Disconnected Micro Service)" ;
        rhdto:HP30_provided_by    <urn:uuid:1cb459ec-83e8-4421-9427-7bae304484a9> ;
        crm:P102_has_title        <urn:uuid:299a4263-e3e8-4621-9297-2fdc7bb64152> ;
        crm:P106_is_composed_of   "Ingestion Service" , "Decisioning Service" , "PostgreSQL + PostGIS" , "Rules Engine" , "Dispatch Service" , "Correlation Service" , "Message Broker (RabbitMQ or Redis Streams)" ;
        crm:P16i_was_used_for     <urn:uuid:57400bdd-e291-4725-ab6c-aa5987d09e59> ;
        crm:P2_has_type           <urn:uuid:dffc4688-da5d-4d39-9269-671d2bcd646b> ;
        crm:P3_has_note           "Set of stateless microservices exposing a stable, versioned REST API to ingest meteorological warnings, correlate them with enriched CH asset data, evaluate risk rules and orchestrate notifications. Provider-agnostic adapters and unified domain model allow external sources (ARSO Slovenia, Meteoalarm EU) to be integrated through a consistent interface. Composed of: ingestion service (polling/webhook), correlation service (spatio-temporal joins), decisioning service (alerting policies), and dispatch service (email SMTP + SMS gateways). Idempotency, deduplication and rate-limiting ensure non-duplicative communications during fast-changing events." ;
        aocat:has_consumed_media  "application/json" ;
        aocat:has_functionality   <urn:uuid:0e79a7a8-c16f-4258-a57b-f36a6d2c24c5> , <urn:uuid:cedcec89-f71d-4aa8-a860-930f05061db2> , <urn:uuid:81f4de2d-101e-4d5d-9a16-6dd0567d2240> , <urn:uuid:cf1aea6e-68a0-4135-bcbe-17d19ef1cc61> , <urn:uuid:f1eeb37a-2974-4daa-b625-bf43d0fd6239> , <urn:uuid:d129a94f-5bd4-4e71-b990-99384d1f265c> , <urn:uuid:5a5cdc16-fd50-4279-8944-9a3a274df452> , <urn:uuid:dffc4688-da5d-4d39-9269-671d2bcd646b> ;
        aocat:has_produced_media  "application/json" .

