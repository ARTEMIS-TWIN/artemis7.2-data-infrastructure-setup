        a                             rhdto:HC21_Digital_Service ;
        rdfs:label                    "Smart Display Case" ;
        rhdto:HP30_provided_by        <urn:uuid:9c1acc26-16fd-49de-af8a-0435837f8f04> ;
        crm:P102_has_title            <urn:uuid:acbc95df-4161-4ad8-8b16-22384ac1d101> ;
        crm:P103_was_intended_for     <urn:uuid:a54846c8-5bb8-4bd3-9e5d-0686a5ff68c5> , <urn:uuid:c9af8991-e2d8-4520-ac91-6b85b162e13d> , <urn:uuid:39984b83-d975-47ee-bdaa-08042e414980> , <urn:uuid:65bc99e0-0fcd-4eba-8470-5ffd46c519a5> ;
        crm:P125_used_object_of_type  "Magnetic/reed switch" , "Edge processing unit (ESP32 or Raspberry Pi)" , "Actuator (ventilation damper)" , "Vibration and shock sensor" , "Illuminance sensor" , "Actuator (light modulation)" , "Relative humidity sensor" , "Temperature sensor" ;
        crm:P16i_was_used_for         <urn:uuid:b9366a94-5225-4c99-809e-b4d86dbeb18e> , <urn:uuid:da77c3cf-67c6-48b6-99b2-91c0bce64728> , <urn:uuid:807f3a3b-03bc-4bf7-bef9-f03cc6d76996> ;
        crm:P2_has_type               <urn:uuid:d17a1738-cdfb-4779-af10-0fe4704429d8> ;
        crm:P3_has_note               "Advanced museum-grade protective display system developed within Pilot 4. It integrates IoT sensors for humidity, temperature and lighting control alongside vandalism detection sensors to monitor shocks, unauthorised access and tampering attempts. Actuator-based protection mechanisms safeguard the displayed artefact. The case is fully integrated into the ARTEMIS platform via exposed REST services, enabling real-time monitoring, automated response and centralised management. The physical system is complemented by a Digital Twin (RHDT) that continuously mirrors the state of the case and its environment, enabling predictive maintenance, remote diagnostics and dynamic interaction with conservation experts, curators and AI-driven analytics. Dimensions: 82×65×200 cm overall; glass display area 70×50×50 cm." ;
        crm:P70i_is_documented_in     <urn:uuid:dd6428a8-6c75-4f41-818d-1c473ea83cb2> ;
