<https://artemis-twin.eu/entity/pilots/artemis_pilot_04>
        a                        crm:E7_Activity ;
        rdfs:label               "Smart display case for CH protection" ;
        crm:P1_is_identified_by  <urn:uuid:51bb5bf4-d556-4786-8633-d39a60c6c1fb> , <urn:uuid:817b15e8-77ef-4f01-b94d-9704e82d8c3e> ;
        crm:P3_has_note          "Pilot 4 focuses on the design, development, and validation of a Smart Display Case for the protection and monitoring of highly sensitive cultural heritage artefacts in museum environments. The pilot is led by SEL and deploys IoT sensors and actuators integrated with the ARTEMIS platform, enabling real-time environmental monitoring, alert generation, and Digital Twin synchronisation for preventive conservation." ;
        crm:P9_consists_of       <https://artemis-twin.eu/entity/artemis_pilot_04/artemis_op_04_03> , <https://artemis-twin.eu/entity/artemis_pilot_04/artemis_op_04_02> , <https://artemis-twin.eu/entity/artemis_pilot_04/artemis_op_04_01> .

