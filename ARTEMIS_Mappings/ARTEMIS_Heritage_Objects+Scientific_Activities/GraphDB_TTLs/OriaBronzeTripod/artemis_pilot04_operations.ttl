        a                             rhdto:HC22_Digital_Operation , crm:E7_Activity ;
        rdfs:label                    "artemis_pilot_04 artemis_op_04_02 Real-Time Digital Twin Synchronisation" ;
        rhdto:HP27_concerns_heritage_entity
                artemis:artemis_he_006 ;
        rhdto:HP28_implemented_using  <https://artemis-twin.eu/entity/services/artemis_CAW-06> , <https://artemis-twin.eu/entity/services/artemis_BEDP-09> ;
        crm:P134_continued            <https://artemis-twin.eu/entity/artemis_pilot_04/artemis_op_04_01> ;
        crm:P1_is_identified_by       <urn:uuid:e86eb085-d331-4396-b3e1-d3f3da886ea9> , <urn:uuid:412d0ec6-7495-425c-a7b6-4ded6790822b> ;
        crm:P21_had_general_purpose   <urn:uuid:163b1bb5-9ba0-47e9-9f5c-e3870f38229e> ;
        crm:P2_has_type               <urn:uuid:54cbe3d9-2d92-4e89-83c8-dd03615e080c> ;
        crm:P3_has_note               "Sensor data collected by the IoT monitoring operation are ingested and propagated to the RHDT of the Smart Display Case. The Digital Twin mirrors the physical state of the case in real time, maintaining a maximum synchronisation lag of 10 seconds. The twin stores historical environmental measurements in the IoT Time-Series NoSQL database and links them semantically to the corresponding IoT Nodes and Activities in the ARTEMIS Triple Store. The operation also handles alert generation when environmental or security thresholds are exceeded." ;
        crm:P4_has_time-span          <urn:uuid:bf67248b-6e8f-4714-8365-34ce8f4fb19c> ;
        crmdig:L10_had_input          <urn:uuid:dbaa8f4c-700a-4923-b592-0725ae2d8421> , <urn:uuid:7939193d-000c-4977-8628-024ff0c7bce1> ;
