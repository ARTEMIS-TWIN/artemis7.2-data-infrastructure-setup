        crm:P16_used_specific_object  <urn:uuid:a902f18f-32d8-4446-8d66-db2d169971a6> , <urn:uuid:392ab28b-f1d5-44d4-96de-dd3a84fb6d27> , <urn:uuid:7fa9fda9-d8ce-4253-9f05-5d9c528ba4d3> , <urn:uuid:bc36d2c7-78f6-49e6-bf9c-97e0132885f5> , <urn:uuid:56f8fbbd-c1e8-4dbf-a9b5-6a39a2420b77> , <urn:uuid:31722e06-41de-4737-9596-db4f77450563> ;
