        a                             rhdto:HC21_Digital_Service ;
        rdfs:label                    "IoCT Services" ;
        rhdto:HP30_provided_by        <urn:uuid:c6614d89-6580-49cc-aa5d-72565e240a7a> ;
        crm:P102_has_title            <urn:uuid:5e30cbd6-11b2-439d-b327-c7d67bb054ab> ;
        crm:P103_was_intended_for     <urn:uuid:655a1c07-0592-484f-9e49-e16f7bfad193> , <urn:uuid:db89d1a0-cde4-4d6f-a664-829d4f51b41e> ;
        crm:P125_used_object_of_type  "DHT22 temperature and humidity sensor" , "On-site meteorological weather station" , "LiPo battery" , "Adafruit TSL2591 light sensor" , "Commercial sensors for moisture content in exterior walls and surrounding soil" , "Sensirion SPS30 particulate matter sensor" , "DFRobot tipping bucket rain gauge" , "DFRobot Solar Power Manager" , "Commercial off-the-shelf temperature and humidity sensors" , "Custom KIK-IRPA IoT nodes (Seeedstudio Xiao ESP32-S3 and Arduino Nano RP2040 Connect)" , "Sensirion SCD30 CO2 sensor" , "Hydreon RG-15 optical rain gauge" , "LoRa/LoRaWAN transceiver (Wio-SX1262 or RFM95W)" ;
        crm:P16i_was_used_for         <urn:uuid:d40a5ba9-cc45-45a6-9a2f-8a7a477b082f> ;
        crm:P2_has_type               <urn:uuid:769dcf56-db95-46ba-b5b5-160eed690f53> ;
        crm:P3_has_note               "A hybrid IoT data collection service combining custom-developed low-power sensor nodes (developed by KIK-IRPA) with commercial off-the-shelf solutions. Custom nodes are based on the Seeedstudio Xiao ESP32-S3 and Arduino Nano RP2040 Connect platforms, integrated with sensors including DHT22 (temperature, humidity), Adafruit TSL2591 (light), Sensirion SCD30 (CO2), Sensirion SPS30 (particulate matter) and various rain gauges (DFRobot tipping bucket, Hydreon RG-15 optical). Nodes are powered by LiPo batteries with DFRobot Solar Power Manager and include on-board flash memory for local data backup. Wireless communication uses built-in WiFi/Bluetooth expanded with LoRa/LoRaWAN transceivers (Wio-SX1262 or RFM95W). Also integrates commercial sensors for temperature, humidity and moisture content in exterior walls and surrounding soil, and standard on-site meteorological weather stations. All data streams transmitted to a cloud-based platform via RESTful services (Artemis IoT Microservices) and MQTT protocol. Firmware developed in Arduino IDE by KIK-IRPA." ;
        aocat:has_consumed_format     "application/json" ;
        aocat:has_functionality       <urn:uuid:88d20717-de96-4d58-9740-42cf2a39be94> , <urn:uuid:b5ccc378-dc5b-48ba-9c7a-0b0d050a249a> , <urn:uuid:769dcf56-db95-46ba-b5b5-160eed690f53> , <urn:uuid:843ed76b-f1a3-4dab-8d84-295ec2d520dd> , <urn:uuid:c1bd658f-afb5-4baa-b774-050e74ce458e> , <urn:uuid:ad77e9f9-d8e5-4f41-94c7-46e9ed88a2cb> , <urn:uuid:22d0679b-9322-4850-b534-4e76df9e96a6> , <urn:uuid:8156b893-0d86-4a21-9ea0-cee01e09cfb6> , <urn:uuid:7c3bf510-e711-457d-97a4-e4bfae77fc18> , <urn:uuid:11674eab-85d0-475d-82b8-046366fb1dd6> , <urn:uuid:eb383d8d-73f4-4489-ac61-d9d77d7533f8> , <urn:uuid:35a2a3f2-97e3-4494-a17d-ffd17073f960> ;
        aocat:has_produced_format     "text/csv" , "application/json" ;
