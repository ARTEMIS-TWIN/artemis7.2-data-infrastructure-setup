<https://artemis-twin.eu/entity/service//BEDP-05>
        a                            rhdto:HC21_Digital_Service ;
        rdfs:label                   "Hypertext Knowledge Base Service" ;
        rhdto:HP30_provided_by       <urn:uuid:e466b036-d83d-4bc6-8a00-1988d2c9051d> ;
        crm:P102_has_title           <urn:uuid:cc1b2a05-b059-43db-98a6-fd4178fe02dc> ;
        crm:P103_was_intended_for    <urn:uuid:e7b1fb9d-2a03-4054-8381-0e79582869c4> , <urn:uuid:6a5f399f-4e36-4343-909e-2d31fc2aeb3a> ;
        crm:P16i_was_used_for        <urn:uuid:930f52ac-2b26-40ce-bc8a-6a87dd0bf115> ;
        crm:P2_has_type              <urn:uuid:7ea8a5f9-aadb-4423-baed-1c9cc981bc60> ;
        crm:P3_has_note              "A service providing context-specific suggestions based on a pilot-specific Knowledge Base (KB). The KB is constructed from pilot-specific datasets and can evolve through expert input, allowing users to contribute to and expand the knowledge over time. Given a defined context (e.g. a selected asset, keyword or annotation), the service offers related content or concepts to support user exploration, enrichment and research. The scope and quality of the KB depends directly on the availability, accessibility and semantic richness of the incorporated datasets. Accessible via a backend REST API integrated with a knowledge graph (e.g. graph database)." ;
        aocat:has_consumed_format    "application/json" ;
        aocat:has_functionality      <urn:uuid:0edc94da-b069-4810-880b-1fc7fce02e4c> , <urn:uuid:7ea8a5f9-aadb-4423-baed-1c9cc981bc60> , <urn:uuid:7ebe33f1-2f31-42cb-889b-57ec0ebb732e> , <urn:uuid:fbf86aec-8243-4059-a19e-f99f7584862d> , <urn:uuid:9856eb31-40da-4ae2-ba48-0984f2b91507> , <urn:uuid:4396d165-8e41-4b91-af28-a8acfcc7f692> , <urn:uuid:ea0874e7-34bc-445c-9694-de8d873b4f13> ;
        aocat:has_produced_format    "application/json" , "application/ld+json" ;
        aocat:has_technical_support  <urn:uuid:a9397aaa-c439-4902-8f4c-dfa54efc9f83> ;
        aocat:is_accessible_at       <urn:uuid:a08bf062-98e7-4201-a894-16db974d5c43> .

