        crm:P103_was_intended_for     <urn:uuid:4619b260-3c67-40ec-990a-de9bf8843e13> , <urn:uuid:c7c722ce-6b59-4b5a-9899-b99cab7d5bb7> , <urn:uuid:409c375d-4fe1-434c-a979-39d963e94b7c> , <urn:uuid:32eb0ff2-0b41-4ea7-bb53-694686d4b437> ;
        crm:P125_used_object_of_type  "Standard workstation or laptop with reliable internet connectivity" , "Secure project cloud infrastructure for hosting REST API simulation microservices, 3D models and simulation outputs" , "Meta Quest 3 VR headset (standalone or tethered mode)" ;
        crm:P16i_was_used_for         <urn:uuid:509477ca-4566-4e05-8928-ce219d11f471> ;
        crm:P2_has_type               <urn:uuid:a8e72c89-78b9-4bdf-a7aa-f795628cfc42> ;
        crm:P3_has_note               "A collaborative VR environment developed in Unity and accessed via Meta Quest 3 headsets, in which all input JSON payloads for ARTEMIS simulation microservices are generated interactively. Allows expert trainers and learners (e.g. university students, professionals in training) to jointly select simulation parameters, define spatial and temporal contexts and visualise simulation outputs in real time. Supports immersive exploration of the RHDT, interactive scenario simulation, and collaborative annotation and discussion of 3D environments and data layers. Compatible with .glb 3D models. Hosted on a secure project cloud environment. No third-party commercial licences required for the simulation microservices." ;
        aocat:has_consumed_format     "application/json" , "model/gltf-binary" ;
        aocat:has_functionality       <urn:uuid:c757e8b4-7eef-45b6-9b25-bcde090b4136> , <urn:uuid:dc374632-d59e-4b80-adc2-8a3caad81cbe> , <urn:uuid:39f0c362-31ac-4d05-8911-694821996bb9> , <urn:uuid:d4803033-4d13-48d7-a65e-83365ef9c29e> , <urn:uuid:a8e72c89-78b9-4bdf-a7aa-f795628cfc42> , <urn:uuid:566164a6-7bd0-4f43-8c70-4c539ff1a754> , <urn:uuid:064a22ee-fb66-4d98-824a-ac0c1b2822e8> , <urn:uuid:112fa7b6-e5a0-4789-9b98-126323ccd8cb> ;
        aocat:has_produced_format     "application/json" ;
        aocat:has_technical_support   <urn:uuid:0a460a0d-cd4a-43a7-aae0-962968327174> ;
        aocat:is_accessible_at        <urn:uuid:b505ab40-5bba-4df4-8eb1-28108a831912> , <urn:uuid:681e0ade-3978-4bce-ac37-6e3ae43ecf9d> .

