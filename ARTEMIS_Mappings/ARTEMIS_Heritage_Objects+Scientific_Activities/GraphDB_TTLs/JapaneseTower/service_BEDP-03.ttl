        crm:P2_has_type              <urn:uuid:0c2ae10f-2a56-48ae-8cd5-e556563f5718> ;
        crm:P3_has_note              "A service enabling users to add persistent, structured or free-text annotations to information entities such as digital assets, documents or metadata records. Annotations can include comments, tags or references and are stored in a format supporting reuse and semantic integration. The service supports collaborative work, allowing multiple users to annotate the same entity simultaneously. Hosted as a RESTful API on a Docker-compatible web server with a database backend (e.g. PostgreSQL) and optional OAuth2 authentication." ;
        aocat:has_consumed_format    "application/json" ;
        aocat:has_functionality      <urn:uuid:c32d3630-8c0a-4ab2-9b8a-2cd62c8a60f9> , <urn:uuid:0c2ae10f-2a56-48ae-8cd5-e556563f5718> , <urn:uuid:865e52ac-a598-4c8a-acff-50a1eeb47565> , <urn:uuid:74b453d6-41c6-4768-8695-909781afbbc8> , <urn:uuid:171df281-7d66-4434-af40-07671e68a5be> , <urn:uuid:ed9529fb-7312-4496-ab32-3cdc52dcc8de> , <urn:uuid:c5425b07-92cb-440d-9fa7-052db87cfebb> ;
        aocat:has_produced_format    "application/json" , "application/ld+json" ;
