        a                             rhdto:HC21_Digital_Service ;
        rdfs:label                    "Phasma3D Viewer" ;
        rhdto:HP30_provided_by        <urn:uuid:f0bad61f-9fcd-44ce-b0a9-d2c92f21deea> ;
        crm:P102_has_title            <urn:uuid:84f135c2-fcb3-4029-ae7a-31afa20a4b14> ;
        crm:P103_was_intended_for     <urn:uuid:6059f065-95d5-44c7-8c94-c3c19e396fee> , <urn:uuid:054f7836-501f-4aa4-a913-48d414d6295a> , <urn:uuid:fa4be445-df46-4275-b1cf-277a73d2f76d> ;
        crm:P106_is_composed_of       "Remote Rendering Service (AUEB-RC external RRS node)" , "Annotation Service (BEAS-01 / BEDP-03)" ;
        crm:P125_used_object_of_type  "Desktop or laptop computer with modern GPU supporting WebGL 2" , "Server with min. 8 CPU cores (Intel i7/i9), min. 32GB RAM, min. 500GB storage for remote rendering" , "Server with NVIDIA RTX class GPU (min. 12GB VRAM, DLSS and OptiX denoiser support; indicative: RTX4090, RTX5090) for remote rendering — provided by AUEB-RC" ;
        crm:P16i_was_used_for         <urn:uuid:3d4cb801-5e2b-4076-972a-3385ceaf3d79> ;
        crm:P2_has_type               <urn:uuid:76b04ef1-2f13-4d34-8dce-5fa5f145aebf> ;
        crm:P3_has_note               "A collaborative 3D visualisation environment that resolves an RHDT project into its constituent entity instances (3D models, annotations, actor information) and renders them in a browser-based interface. Supports both client-side rendering via WebGL for mid-/high-tier devices and server-side remote rendering for large fragment collections and thin clients, enabling realistic illumination of results compatible with physical inspection. Includes 3D annotation tools (via ARTEMIS Annotation Services BEAS-01), geometry optimisation with Level of Detail (LOD) processing for 3D format conversion, and collaborative multi-user interaction. Server-side rendering is provided by AUEB-RC as an external Remote Rendering Server node." ;
        aocat:has_consumed_format     "model/gltf-binary" , "application/json" ;
        aocat:has_functionality       <urn:uuid:bd8418bd-ec31-418c-a140-5b82965c5e49> , <urn:uuid:40eb9080-041a-4e83-8a84-59d5223e664a> , <urn:uuid:76b04ef1-2f13-4d34-8dce-5fa5f145aebf> , <urn:uuid:aa8ab43e-93cf-412f-9634-0b3249a92bdc> , <urn:uuid:fa516a66-590d-4944-8a30-11f2db7bbeb4> , <urn:uuid:67007483-7556-4fe8-a979-9a77f9560120> , <urn:uuid:e85825cb-efae-4bc9-83ee-ccf25dee5408> ;
        aocat:has_produced_format     "image/png" , "application/json" ;
        aocat:has_technical_support   <urn:uuid:b2f5ba8e-6135-40bc-87ca-5f95a1e51e56> ;
