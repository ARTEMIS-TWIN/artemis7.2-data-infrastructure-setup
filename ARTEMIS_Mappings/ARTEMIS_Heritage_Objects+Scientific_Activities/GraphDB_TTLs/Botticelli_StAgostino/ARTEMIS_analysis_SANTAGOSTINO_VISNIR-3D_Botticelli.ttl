        a                crmhs:HS4_Method ;
        rdfs:label       "Visible-Near Infrared (VIS-NIR) Reflectance Imaging Spectroscopy (RIS)" ;
        crm:P3_has_note  "Multispectral/Hyperspectral (MS/HS) reflectance imaging spectroscopy (RIS) exploiting the property of IR radiation to penetrate pictorial layers, revealing properties and composition of the probed matter." .

