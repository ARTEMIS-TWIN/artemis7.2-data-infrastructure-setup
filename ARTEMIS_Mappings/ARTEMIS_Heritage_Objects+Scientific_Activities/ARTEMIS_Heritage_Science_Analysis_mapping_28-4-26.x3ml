   <mappings>
      <mapping>
         <domain>
            <source_node>/artemis_analysis/analysis</source_node>
            <target_node>
               <entity>
                  <type>crmhs:HS3_Analysis</type>
                  <instance_generator name="ArtemisURI">
                     <arg name="id" type="constant">analysis</arg>
                  </instance_generator>
                  <label_generator name="Literal">
                     <arg name="text" type="xpath">analysis_title/text()</arg>
                  </label_generator>
               </entity>
            </target_node>
            <comments>
               <comment type="">
                  <rationale>ANALYSIS</rationale>
                  <alternatives/>
                  <typical_mistakes/>
                  <local_habits/>
                  <link_to_cook_book/>
                  <example>
                     <example_source/>
                     <example_target/>
                  </example>
                  <comments_last_update date="2026-04-26 22:27:00" person="Laura Tonti"/>
               </comment>
            </comments>
         </domain>
         <link>
            <path>
               <source_relation>
                  <relation>analysis_was_performed_on</relation>
               </source_relation>
