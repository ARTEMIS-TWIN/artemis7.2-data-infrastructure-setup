                  <relationship>crmhs:HSP2_was_performed_on</relationship>
               </target_relation>
            </path>
            <range>
               <source_node>analysis_was_performed_on</source_node>
               <target_node>
                  <entity>
                     <type>crmhs:HS2_Heritage_Science_Object</type>
                     <type>crmhs:HS6_Study_Object</type>
                     <type>rhdto:HC3_Tangible_Entity</type>
                     <type>aocat:AO_Object</type>
                     <instance_generator name="URIorUUID">
                        <arg name="text" type="xpath">../heritage_object_artemis_id/text()</arg>
                     </instance_generator>
                     <label_generator name="Literal">
                        <arg name="text" type="xpath">text()</arg>
                     </label_generator>
                  </entity>
               </target_node>
            </range>
         </link>
