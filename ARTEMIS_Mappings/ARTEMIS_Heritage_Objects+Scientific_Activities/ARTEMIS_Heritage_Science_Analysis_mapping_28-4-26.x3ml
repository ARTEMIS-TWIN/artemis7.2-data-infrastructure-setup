         </link>
         <link>
            <path>
               <source_relation>
                  <relation>object_or_area_or_portion_or_sample_analysed/object_area_sample</relation>
               </source_relation>
               <target_relation>
                  <if>
                     <and>
                        <if>
                           <not>
                              <if>
                                 <equals value="Sample">object_area_sample_type</equals>
                              </if>
                           </not>
                        </if>
                        <if>
                           <not>
                              <if>
                                 <equals value="Portion">object_area_sample_type</equals>
                              </if>
                           </not>
                        </if>
                        <if>
                           <not>
                              <if>
                                 <equals value="Area">object_area_sample_type</equals>
                              </if>
                           </not>
                        </if>
                     </and>
                  </if>
                  <relationship>crmhs:HSP4_analysed</relationship>
               </target_relation>
