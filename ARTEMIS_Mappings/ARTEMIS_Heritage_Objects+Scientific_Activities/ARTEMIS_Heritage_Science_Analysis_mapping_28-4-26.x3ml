         <link>
            <path>
               <source_relation>
                  <relation>time_span/span</relation>
               </source_relation>
               <target_relation>
                  <relationship>crm:P4_has_time-span</relationship>
               </target_relation>
            </path>
            <range>
               <source_node>time_span/span</source_node>
               <target_node>
                  <entity>
                     <type>crm:E52_Time-Span</type>
                     <instance_generator name="UUID"/>
                     <label_generator name="Literal">
                        <arg name="text" type="xpath">concat(from, '-', until)</arg>
                     </label_generator>
                     <additional>
                        <relationship>crm:P79_beginning_is_qualified_by</relationship>
                        <entity>
                           <type>rdfs:Literal</type>
                           <instance_generator name="Literal">
                              <arg name="text" type="xpath">from/text()</arg>
                           </instance_generator>
                        </entity>
                     </additional>
                     <additional>
                        <relationship>crm:P80_end_is_qualified_by</relationship>
                        <entity>
                           <type>rdfs:Literal</type>
                           <instance_generator name="Literal">
                              <arg name="text" type="xpath">until/text()</arg>
                           </instance_generator>
                        </entity>
                     </additional>
                     <additional>
                        <relationship>aocat:from</relationship>
                        <entity>
                           <type>rdfs:Literal</type>
                           <instance_generator name="Literal">
                              <arg name="text" type="xpath">from/text()</arg>
                           </instance_generator>
                        </entity>
                     </additional>
                     <additional>
                        <relationship>aocat:until</relationship>
                        <entity>
                           <type>rdfs:Literal</type>
                           <instance_generator name="Literal">
                              <arg name="text" type="xpath">until/text()</arg>
                           </instance_generator>
                        </entity>
                     </additional>
                  </entity>
               </target_node>
            </range>
