        a                         rhdto:HC21_Digital_Service ;
        rdfs:label                "Meteorological Station Simulator" ;
        rhdto:HP30_provided_by    <urn:uuid:a4ced932-4c45-402f-914a-e5a1d7721104> ;
        crm:P102_has_title        <urn:uuid:8dcce50a-79ac-40a5-bca4-bc20ebc362e8> ;
        crm:P16i_was_used_for     <urn:uuid:b1535851-11c8-4400-b853-5f4f7bd48ede> , <urn:uuid:7d266b65-1d06-4005-bbae-2523214133d6> ;
        crm:P2_has_type           <urn:uuid:73bb3901-68d2-40ae-9328-0c38cca4e466> ;
        crm:P3_has_note           "Modular REST API microservice emulating the operation of a virtual weather station at a user-specified location and period. Leverages high-resolution Copernicus Climate Data Store (CDS) and CMIP6 climate projection datasets to generate time series of key climatic variables (temperature, precipitation, humidity, solar radiation, pressure) for both historical and future scenarios. Embedded in the pilots' VR environments to simulate dynamic climate conditions." ;
        aocat:has_consumed_media  "application/json" ;
        aocat:has_functionality   <urn:uuid:4ee12ad0-e392-4cf2-b8c9-9c2cbe4a01a4> , <urn:uuid:4c570e0a-a960-463f-9af4-234cd20f6f32> , <urn:uuid:31f10e56-1426-43d3-9ef2-e554161164d4> , <urn:uuid:a9bb42ff-b2a0-4647-aa00-df90f9821b89> , <urn:uuid:73bb3901-68d2-40ae-9328-0c38cca4e466> ;
        aocat:has_produced_media  "application/json" .
