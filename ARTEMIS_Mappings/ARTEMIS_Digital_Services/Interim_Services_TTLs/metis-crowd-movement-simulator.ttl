        a                             rhdto:HC21_Digital_Service ;
        rdfs:label                    "METIS Crowd Movement Simulator" ;
        rhdto:HP30_provided_by        <urn:uuid:ac55638a-7244-44f2-a48b-65e0d699ff04> ;
        crm:P102_has_title            <urn:uuid:c23a4c92-6360-476b-9c32-c53375702dac> ;
        crm:P103_was_intended_for     <urn:uuid:05f2e9fa-9886-4181-8328-77022bd9f406> , <urn:uuid:44d3d211-a26d-49bc-9aba-46c8687a7d04> , <urn:uuid:84fec015-1727-4f0b-a509-586b23e489ee> , <urn:uuid:1aec346c-d72f-44cc-8e89-eb23903226d3> , <urn:uuid:a9bfd156-7f6a-4195-98fe-243278c1ec94> , <urn:uuid:543000c2-5acd-4131-ab16-045900a2c3e6> , <urn:uuid:d19f106a-d76b-4e37-99af-856be4f89d80> , <urn:uuid:b9d769c3-ccd4-4cc9-9e00-9a60b67c044a> ;
        crm:P106_is_composed_of       "Reinforcement Learning Libraries (ML-Agents Toolkit, Stable-Baselines3)" , "Python-based API Wrapper" , "REST API Framework (FastAPI or Flask)" , "Unity Engine (headless mode)" ;
        crm:P16i_was_used_for         <urn:uuid:87555be9-fb5f-4842-8f6e-ce1429940372> , <urn:uuid:6d7b0c24-2657-48ec-b0fe-a1de98099a17> , <urn:uuid:c66252c1-e942-4f30-9e18-ddac035fa171> ;
        crm:P2_has_type               <urn:uuid:1e709864-e4ac-4058-8dd5-daed99712153> ;
        crm:P3_has_note               "GPU-accelerated, multi-agent-based simulation service for real-time crisis and crowd behaviour simulation, developed in Unity. In the ARTEMIS context, METIS is being adapted to operate as a cloud/web-enabled service with a RESTful API, receiving JSON-encoded input requests describing the simulation experiment (layout, agents, hazards, objectives) and responding with JSON output logs capturing agent-level events and state transitions in time-stepped format. Supports algorithms ranging from A* to Deep Reinforcement Learning (PPO, SAC) and agents with diverse physical and behavioural attributes (age, speed, reaction time, risk aversion)." ;
        crm:P70i_is_documented_in     <urn:uuid:56ebe5df-aa9c-40dc-b965-6f4d03cb1883> , <https://arxiv.org/abs/2009.03934> ;
        aocat:has_consumed_format     "JSON Simulation Scenario Specification" ;
        aocat:has_consumed_media      "application/json" ;
        aocat:has_functionality       <urn:uuid:aa4aabf1-2877-4dd6-af3e-2c09ade602d3> , <urn:uuid:46167d15-2f44-4ab8-9c78-835a619bc571> , <urn:uuid:923abd7f-f901-4c92-96ea-d6f0c0b73972> , <urn:uuid:f4970585-857c-4272-996c-a3caf6d4505c> , <urn:uuid:1e709864-e4ac-4058-8dd5-daed99712153> , <urn:uuid:09583041-1d6f-4d6d-ac0c-97c5e3f0e94b> , <urn:uuid:21d29c3f-4a47-44b8-be96-93beaefc6844> ;
        aocat:has_produced_format     "JSON Time-stepped Agent Event Log" ;
        aocat:has_produced_media      "application/json" ;
        aocat:has_supported_language  lexvo:eng ;
        aocat:has_technical_support   <urn:uuid:9d6b12cf-8591-4b99-ad1e-0c3776d752df> .
