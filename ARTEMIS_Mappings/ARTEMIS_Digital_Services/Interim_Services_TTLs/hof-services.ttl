        crm:P2_has_type           <urn:uuid:30315812-ad23-45bf-a4d8-13b7a25f82b7> ;
        crm:P3_has_note           "Suite of services provided by HOF, comprising: (1) an Annotation Service enabling persistent structured or free-text annotations on information entities, with support for collaborative work; (2) a Navigational Hypertext Service managing links of arbitrary arity between information entities, represented in machine-readable format for knowledge-graph integration; (3) a Hypertext Knowledge Base Service providing context-specific suggestions from a pilot-specific KB that can evolve through expert input. RESTful APIs hosted on standard Docker-compatible web servers, backed by PostgreSQL with optional OAuth2 authentication." ;
        aocat:has_consumed_media  "application/json" ;
