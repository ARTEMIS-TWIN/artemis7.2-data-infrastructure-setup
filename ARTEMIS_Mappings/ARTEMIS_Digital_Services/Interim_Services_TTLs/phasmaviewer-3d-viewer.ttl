        crm:P106_is_composed_of    "PhasmaViewer Client (WebGL 2)" , "Remote Rendering Services (RTX GPU cluster, AUEB-RC)" , "Geometry Services (containerised)" ;
        crm:P16i_was_used_for      <urn:uuid:14c28868-67d9-40cd-9c65-1c18f7519944> , <urn:uuid:12f86297-cb1f-44f9-a807-083c3dfa7ecf> , <urn:uuid:f8ccb14b-b152-4ede-94fe-5cc271e00124> , <urn:uuid:3fdebf88-4fb0-466c-8ae7-7d3343ebb57c> ;
        crm:P2_has_type            <urn:uuid:197ed2d7-38e3-4630-b321-b6e29e7a17be> ;
        crm:P3_has_note            "Browser-based WebGL 2 3D viewer for cultural heritage assets with cataloguing, client-side rendering, and server-side remote rendering for large fragment collections and thin clients. Supports 3D annotations (integrates the ARTEMIS Annotation Service), geometry optimisation via 3D format conversion and Level of Detail (LOD) processing. For large models or thin clients, realistic remote rendering uses NVIDIA RTX-class GPUs with DLSS and OptiX denoiser support." ;
        aocat:has_functionality    <urn:uuid:ed6d145a-4408-4ee8-b85a-b6bb1ee7435a> , <urn:uuid:197ed2d7-38e3-4630-b321-b6e29e7a17be> , <urn:uuid:16106af0-a4e1-4944-b51b-845cb7b41e78> , <urn:uuid:fca330bc-ecd9-4dbf-859e-5abc79a1f695> , <urn:uuid:c4a2bc42-d087-4e17-b7cd-6f1213670f66> , <urn:uuid:afef47eb-ccd4-4209-b4d6-f038ddf4899c> , <urn:uuid:0ef570c0-6836-4c2c-81bc-12a62db2e9b9> .

