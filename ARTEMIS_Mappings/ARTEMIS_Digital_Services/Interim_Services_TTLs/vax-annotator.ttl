        crm:P106_is_composed_of       "Meta XR All-in SDK (v74.0.3)" , "Vuplex 3D WebView for Android (v4.12)" , "Unity Game Engine (v2022.3.61f)" ;
        crm:P125_used_object_of_type  "Meta Quest 3 VR Headset" ;
        crm:P16i_was_used_for         <urn:uuid:fcb3c3a6-4201-427d-b099-4d6a42a98aca> , <urn:uuid:d4eedc2f-f6d9-4254-998e-7282f4967e1d> , <urn:uuid:4b598e52-e717-44d5-885d-cdd4e9c2397d> ;
        crm:P2_has_type               <urn:uuid:098589bf-0da7-4a7b-8361-9e777b84d943> ;
        crm:P3_has_note               "VR/AR/XR application for Meta Quest headsets serving as a professional tool for stakeholder interaction with Reactive Heritage Digital Twins (RHDT). Enables stakeholders to observe, explore and traverse 3D digital replicas. Supports six annotation types (POI-based, primitive-based, lasso, contextual-entity, measurement, asset annotations) organisable in custom groups. Multi-user collaborative workspace with real-time synchronous interaction and persistent state. Interaction via hand tracking, virtual keyboard, dictation (speech-to-text), voice commands, and text-to-speech. Includes integrated web browser. Supports both full VR and AR passthrough modes." ;
        aocat:has_consumed_media      "application/json" ;
        aocat:has_functionality       <urn:uuid:7403617a-7ea5-432b-beb3-cf77f72d45b8> , <urn:uuid:c3742197-678d-4502-b2bb-28b6d1845a6e> , <urn:uuid:f9f8aa3d-cec0-4871-a471-18cc8084dcc1> , <urn:uuid:84ac2bf5-2f52-4e68-aef3-1496441358fa> , <urn:uuid:da34f867-3938-4c93-a315-42c8290c1ae1> , <urn:uuid:3d5d14ca-c3f7-4034-82f5-ebe698982d4d> , <urn:uuid:f675401b-7197-4ff8-8530-610b992074c0> , <urn:uuid:31188c21-caa8-4142-b0b3-409cf1324415> , <urn:uuid:33638c1b-1908-459b-97ef-9915a2bd7182> , <urn:uuid:098589bf-0da7-4a7b-8361-9e777b84d943> , <urn:uuid:42a10cec-3de6-4a89-a4e0-f457da2092f7> , <urn:uuid:6d651fce-f95d-4fa4-a67e-5c23690ad9f3> ;
