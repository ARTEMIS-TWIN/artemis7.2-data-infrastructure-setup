        a                             rhdto:HC21_Digital_Service ;
        rdfs:label                    "VAX Annotator" ;
        rhdto:HP30_provided_by        <urn:uuid:0b619c46-3389-4958-9849-7583fd89fcee> ;
        crm:P102_has_title            <urn:uuid:3bccb953-c218-427a-b3c9-b0a661f19a22> ;
