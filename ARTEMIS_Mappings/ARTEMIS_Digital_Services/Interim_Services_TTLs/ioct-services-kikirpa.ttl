        a                             rhdto:HC21_Digital_Service ;
        rdfs:label                    "IoCT Services (KIK-IRPA)" ;
        rhdto:HP30_provided_by        <urn:uuid:831d827b-946e-40ea-9a5f-f3f0e8a3ef45> ;
        crm:P102_has_title            <urn:uuid:6a5a9305-068b-4838-a093-40daa06d0e52> ;
        crm:P125_used_object_of_type  "Sensirion SCD30 CO2 Sensor" , "Adafruit TSL2591 Light Sensor" , "Sensirion SPS30 Particulate Matter Sensor" , "Arduino Nano RP2040 Connect" , "DHT22 Temperature/Humidity Sensor" , "DFRobot Tipping Bucket Rain Gauge" , "LoRa/LoRaWAN Transceiver (Wio-SX1262, RFM95W)" , "On-site Weather Station" , "Hydreon RG-15 Optical Rain Gauge" , "Seeedstudio Xiao ESP32-S3" ;
        crm:P16i_was_used_for         <urn:uuid:4c77c253-8c73-4dcc-bc8f-44146df50c72> , <urn:uuid:1a93cb3c-1af1-4cca-8ba6-bbb4eb94ab08> , <urn:uuid:a260f8f4-32c5-4c4f-95d4-e09fa5e42fd9> ;
        crm:P2_has_type               <urn:uuid:539424dc-e94d-486c-9373-0a4a1d6411b8> ;
        crm:P3_has_note               "IoT service implementing a hybrid data collection strategy, combining custom-developed sensor platforms and commercial off-the-shelf solutions. Centred on low-power standalone IoT nodes developed by KIK-IRPA for measuring temperature, relative humidity, light, CO2, particulate matter and wind-driven rain on facades. Integrates commercial sensors for temperature/humidity and wall/soil moisture, plus on-site meteorological stations. Data transmission to the ARTEMIS infrastructure via RESTful services (ARTEMIS IoT Microservices) and MQTT protocol." ;
        aocat:has_consumed_media      "application/json" ;
        aocat:has_functionality       <urn:uuid:539424dc-e94d-486c-9373-0a4a1d6411b8> , <urn:uuid:08d3bfb4-f58e-41b1-95e9-d8b90ec36525> , <urn:uuid:93f03ce7-220d-489d-a9b2-10bd52245441> , <urn:uuid:65091709-05b7-4404-9f86-058a0707f37f> , <urn:uuid:a3f9aa89-e8ac-4694-9654-43e8191b24f7> ;
        aocat:has_produced_media      "application/json" .

