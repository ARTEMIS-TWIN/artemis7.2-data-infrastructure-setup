        crm:P103_was_intended_for  <urn:uuid:9b22bb5d-f501-43aa-939e-2c9e034a1e2b> , <urn:uuid:e66a47c0-1653-49dd-be2f-1b0e0f3c2eab> , <urn:uuid:5a3fd935-bf73-44b5-b79b-7d8b28faa766> ;
        crm:P106_is_composed_of    "Node.js REST API Server (Express.js v4.18+)" , "Export and Backup Services" , "Validation and Processing Engine" , "Audit and Logging Subsystem" , "MongoDB NoSQL Database (v5.0+)" ;
        crm:P16i_was_used_for      <urn:uuid:7a75b868-984a-45f8-8972-27809ad14de5> , <urn:uuid:2ffb76d6-0443-408e-bd46-821ee2c3319e> , <urn:uuid:072b6e58-4290-4b8a-8e92-8433c4cdd27c> ;
        crm:P2_has_type            <urn:uuid:a507085a-4db8-4c68-864d-ba413f90da09> ;
        crm:P3_has_note            "Microservices architecture providing backend infrastructure for spatial data management and contextual information storage associated with 3D digital heritage assets. Enterprise-grade REST API endpoints supporting full CRUD operations for spatial annotation data, with data persistence, validation engines and real-time synchronization. Endpoints follow the pattern /api/assets/{assetId}/annotations with automatic type-specific validation and geometric calculations, supporting six annotation data schemas: Point-of-Interest, Primitive-based, Lasso-based, Contextual Entity, Asset-level, and Measurement. Annotation Grouping API provided via /api/assets/{assetId}/annotation-groups." ;
        aocat:has_consumed_media   "application/json" ;
        aocat:has_functionality    <urn:uuid:8cec3cce-b868-402f-9508-7fbc0488b178> , <urn:uuid:9d239fa7-492b-432b-baf4-2fec3c4dbf3c> , <urn:uuid:da954dcb-5454-417a-a794-6d473003d1f3> , <urn:uuid:42ea4d41-ace2-40ef-a967-2a71f4ad15a6> , <urn:uuid:90b63eb2-6eb2-46d7-950b-d4a781ccf49d> , <urn:uuid:4a21fc52-0e94-4164-909f-080b763d7d2c> , <urn:uuid:a507085a-4db8-4c68-864d-ba413f90da09> , <urn:uuid:2a721e87-60cf-4755-bbc9-db2acc0ffd31> , <urn:uuid:c1140ec1-ce2c-4226-9998-6c0d283d7c6c> , <urn:uuid:cfddc147-5712-4f61-beea-405bd9594406> , <urn:uuid:7aa56e4f-1f89-49b7-86bd-549b38ff506f> , <urn:uuid:b59c41d0-41b8-44c0-9b68-05f3d3ca46a7> , <urn:uuid:e6a772c6-8b37-43db-9531-4e094cba9477> ;
