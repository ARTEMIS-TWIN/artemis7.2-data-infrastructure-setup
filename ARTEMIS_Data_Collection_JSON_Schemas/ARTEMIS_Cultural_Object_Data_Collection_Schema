{
    "$schema": "https://json-schema.org/draft/2020-12/schema",
    "$id": "https://vast-lab.org/artemis/schema/cultural-object-form",
    "title": "ARTEMIS Cultural Heritage Object — Data Collection Form",
    "description": "Data collection schema for cultural heritage objects in the ARTEMIS project. ARTEMIS Ontology Task Force – 13.04.2026.",
    "type": "object",
    "required":
    [
        "cultural_object"
    ],
    "properties":
    {
        "cultural_object":
        {
            "title": "Cultural Object",
            "type": "object",
            "required":
            [
                "object_id",
                "object_label",
                "object_name",
                "object_description",
                "object_types"
            ],
            "properties":
            {
                "object_id":
                {
                    "title": "Object ID",
                    "description": "Unique identifier for the cultural object within the ARTEMIS project. Use a short alphanumeric string with no spaces.",
                    "type": "string",
                    "examples":
                    [
                        "stonehenge_001",
                        "pompeii_fresco_003"
                    ]
                },
                "object_label":
                {
                    "title": "Object Label",
                    "description": "Short human-readable label for the cultural object.",
                    "type": "string",
                    "examples":
                    [
                        "Stonehenge"
                    ]
                },
                "object_name":
                {
                    "title": "Object Name",
                    "description": "Full name or title of the cultural object as known in literature or catalogues.",
                    "type": "string",
                    "examples":
                    [
                        "Stonehenge – Neolithic henge monument, Amesbury, Wiltshire, England"
                    ]
                },
                "object_description":
                {
                    "title": "Description",
                    "description": "Free-text description of the heritage object: significance, state of preservation, and any relevant contextual information.",
                    "type": "string"
                },
                "object_external_uri":
                {
                    "title": "External URI",
                    "description": "Linked Data URI to an external description of the object (e.g. Wikidata, Europeana, national heritage register).",
                    "type":
                    [
                        "string",
                        "null"
                    ],
                    "format": "uri",
                    "examples":
                    [
                        "https://www.wikidata.org/wiki/Q39671"
                    ]
                },
                "object_types":
                {
                    "title": "Object Types",
                    "description": "One or more cultural object types according to the Getty AAT thesaurus. At least one type is required.",
                    "type": "array",
                    "minItems": 1,
                    "items":
                    {
                        "type": "object",
                        "required":
                        [
                            "type_label",
                            "type_uri"
                        ],
                        "properties":
                        {
                            "type_label":
                            {
                                "title": "Type Label",
                                "description": "Getty AAT label for the object type.",
                                "type": "string",
                                "examples":
                                [
                                    "cities",
                                    "megalithic monuments"
                                ]
                            },
                            "type_uri":
                            {
                                "title": "Type URI",
                                "description": "Getty AAT URI for the object type.",
                                "type":
                                [
                                    "string",
                                    "null"
                                ],
                                "format": "uri",
                                "examples":
                                [
                                    "http://vocab.getty.edu/aat/300008389",
                                    "http://vocab.getty.edu/aat/300006983"
                                ]
                            }
                        }
                    }
                },
                "object_materials":
                {
                    "title": "Materials",
                    "description": "Physical materials the object is made of. Use Getty AAT terms where possible.",
                    "type": "array",
                    "items":
                    {
                        "type": "object",
                        "properties":
                        {
                            "material_label":
                            {
                                "title": "Material Label",
                                "description": "Getty AAT label for the material.",
                                "type": "string",
                                "examples":
                                [
                                    "brick (clay material)",
                                    "sarsen"
                                ]
                            },
                            "material_uri":
                            {
                                "title": "Material URI",
                                "description": "Getty AAT URI for the material.",
                                "type":
                                [
                                    "string",
                                    "null"
                                ],
                                "format": "uri",
                                "examples":
                                [
                                    "http://vocab.getty.edu/aat/300010463",
                                    "http://vocab.getty.edu/aat/300011672"
                                ]
                            }
                        }
                    }
                },
                "object_images":
                {
                    "title": "Images",
                    "description": "Images of the object. Provide publicly accessible URLs.",
                    "type": "array",
                    "items":
                    {
                        "type": "object",
                        "required":
                        [
                            "image_url"
                        ],
                        "properties":
                        {
                            "image_url":
                            {
                                "title": "Image URL",
                                "type":
                                [
                                    "string",
                                    "null"
                                ],
                                "format": "uri"
                            },
                            "image_caption":
                            {
                                "title": "Caption",
                                "type": "string"
                            }
                        }
                    }
                },
                "object_current_owners":
                {
                    "title": "Current Owners",
                    "description": "Institution(s) or individual(s) that currently own the object.",
                    "type": "array",
                    "items":
                    {
                        "type": "object",
                        "required":
                        [
                            "owner_name",
                            "owner_type"
                        ],
                        "properties":
                        {
                            "owner_name":
                            {
                                "title": "Name",
                                "type": "string",
                                "examples":
                                [
                                    "English Heritage"
                                ]
                            },
                            "owner_type":
                            {
                                "title": "Type",
                                "type":
                                [
                                    "string",
                                    "null"
                                ],
                                "enum":
                                [
                                    "Person",
                                    "Group"
                                ]
                            },
                            "owner_uri":
                            {
                                "title": "Authority URI",
                                "description": "VIAF, Getty ULAN or Wikidata URI.",
                                "type":
                                [
                                    "string",
                                    "null"
                                ],
                                "format": "uri"
                            },
                            "owner_email":
                            {
                                "title": "Email",
                                "type":
                                [
                                    "string",
                                    "null"
                                ],
                                "format": "email"
                            },
                            "owner_homepage":
                            {
                                "title": "Homepage",
                                "type":
                                [
                                    "string",
                                    "null"
                                ],
                                "format": "uri"
                            },
                            "owner_note":
                            {
                                "title": "Note",
                                "description": "Additional information about the owner, e.g. contested ownership.",
                                "type": "string"
                            }
                        }
                    }
                },
                "object_makers":
                {
                    "title": "Makers",
                    "description": "Person(s), group(s) or culture(s) responsible for making the object. Omit or use 'note' if anonymous or prehistoric.",
                    "type": "array",
                    "items":
                    {
                        "type": "object",
                        "required":
                        [
                            "maker_name",
                            "maker_type"
                        ],
                        "properties":
                        {
                            "maker_name":
                            {
                                "title": "Name",
                                "type": "string"
                            },
                            "maker_type":
                            {
                                "title": "Type",
                                "type":
                                [
                                    "string",
                                    "null"
                                ],
                                "enum":
                                [
                                    "Person",
                                    "Group"
                                ]
                            },
                            "maker_uri":
                            {
                                "title": "Authority URI",
                                "description": "VIAF, Getty ULAN or Wikidata URI.",
                                "type":
                                [
                                    "string",
                                    "null"
                                ],
                                "format": "uri"
                            },
                            "maker_email":
                            {
                                "title": "Email",
                                "type":
                                [
                                    "string",
                                    "null"
                                ],
                                "format": "email"
                            },
                            "maker_homepage":
                            {
                                "title": "Homepage",
                                "type":
                                [
                                    "string",
                                    "null"
                                ],
                                "format": "uri"
                            },
                            "maker_note":
                            {
                                "title": "Note",
                                "type": "string"
                            }
                        }
                    }
                },
                "object_production_periods":
                {
                    "title": "Production Periods",
                    "description": "Cultural or chronological period(s) during which the object was made. Years as integers; negative = BCE.",
                    "type": "array",
                    "items":
                    {
                        "type": "object",
                        "required":
                        [
                            "period_label"
                        ],
                        "properties":
                        {
                            "period_label":
                            {
                                "title": "Period Label",
                                "description": "PeriodO label or equivalent.",
                                "type": "string",
                                "examples":
                                [
                                    "Bronze Age - England"
                                ]
                            },
                            "period_start_year":
                            {
                                "title": "Start Year",
                                "description": "Approximate start year. Negative integer for BCE (e.g. -2600 for 2600 BCE).",
                                "type":
                                [
                                    "integer",
                                    "null"
                                ]
                            },
                            "period_end_year":
                            {
                                "title": "End Year",
                                "description": "Approximate end year. Negative integer for BCE.",
                                "type":
                                [
                                    "integer",
                                    "null"
                                ]
                            },
                            "period_o_uri":
                            {
                                "title": "PeriodO URI",
                                "description": "URI from https://perio.do",
                                "type":
                                [
                                    "string",
                                    "null"
                                ],
                                "format": "uri",
                                "examples":
                                [
                                    "http://n2t.net/ark:/99152/p0kh9ds7q8m"
                                ]
                            }
                        }
                    }
                },
                "object_current_location":
                {
                    "title": "Current Location",
                    "description": "Where the object is currently located.",
                    "type": "object",
                    "properties":
                    {
                        "location_name":
                        {
                            "title": "Location Name",
                            "description": "Full human-readable name of the location.",
                            "type": "string",
                            "examples":
                            [
                                "Stonehenge, Amesbury, Wiltshire, United Kingdom"
                            ]
                        },
                        "location_id":
                        {
                            "title": "GeoNames ID",
                            "description": "GeoNames URI for the location.",
                            "type":
                            [
                                "string",
                                "null"
                            ],
                            "format": "uri",
                            "examples":
                            [
                                "https://www.geonames.org/2636812/"
                            ]
                        },
                        "location_country_name":
                        {
                            "title": "Country Name",
                            "type": "string",
                            "examples":
                            [
                                "United Kingdom"
                            ]
                        },
                        "location_country_uri":
                        {
                            "title": "Country GeoNames URI",
                            "type":
                            [
                                "string",
                                "null"
                            ],
                            "format": "uri",
                            "examples":
                            [
                                "https://www.geonames.org/2635167"
                            ]
                        },
                        "location_latitude":
                        {
                            "title": "Latitude",
                            "description": "Decimal degrees WGS84. Negative = South.",
                            "type":
                            [
                                "number",
                                "null"
                            ]
                        },
                        "location_longitude":
                        {
                            "title": "Longitude",
                            "description": "Decimal degrees WGS84. Negative = West.",
                            "type":
                            [
                                "number",
                                "null"
                            ]
                        }
                    }
                },
                "object_provenance":
                {
                    "title": "Provenance / Discovery",
                    "description": "Archaeological or scientific activities through which the object was found or studied.",
                    "type": "array",
                    "items":
                    {
                        "type": "object",
                        "required":
                        [
                            "provenance_label"
                        ],
                        "properties":
                        {
                            "provenance_label":
                            {
                                "title": "Event Label",
                                "description": "Name of the discovery event, mission or excavation.",
                                "type": "string",
                                "examples":
                                [
                                    "Stonehenge Riverside Project (2003–2009)"
                                ]
                            },
                            "provenance_type":
                            {
                                "title": "Event Type",
                                "type": "string",
                                "examples":
                                [
                                    "archaeological excavation"
                                ]
                            },
                            "provenance_start_year":
                            {
                                "title": "Start Year",
                                "type":
                                [
                                    "integer",
                                    "null"
                                ]
                            },
                            "provenance_end_year":
                            {
                                "title": "End Year",
                                "type":
                                [
                                    "integer",
                                    "null"
                                ]
                            },
                            "provenance_actors":
                            {
                                "title": "Actors",
                                "description": "Persons or organisations involved in this activity.",
                                "type": "array",
                                "items":
                                {
                                    "type": "object",
                                    "required":
                                    [
                                        "provenance_actor_name",
                                        "provenance_actor_type"
                                    ],
                                    "properties":
                                    {
                                        "provenance_actor_name":
                                        {
                                            "title": "Name",
                                            "type": "string"
                                        },
                                        "provenance_actor_type":
                                        {
                                            "title": "Type",
                                            "type":
                                            [
                                                "string",
                                                "null"
                                            ],
                                            "enum":
                                            [
                                                "Person",
                                                "Group"
                                            ]
                                        },
                                        "provenance_actor_uri":
                                        {
                                            "title": "Authority URI",
                                            "description": "VIAF, Getty ULAN or Wikidata URI.",
                                            "type":
                                            [
                                                "string",
                                                "null"
                                            ],
                                            "format": "uri"
                                        },
                                        "provenance_actor_email":
                                        {
                                            "title": "Email",
                                            "type":
                                            [
                                                "string",
                                                "null"
                                            ],
                                            "format": "email"
                                        },
                                        "provenance_actor_homepage":
                                        {
                                            "title": "Homepage",
                                            "type":
                                            [
                                                "string",
                                                "null"
                                            ],
                                            "format": "uri"
                                        },
                                        "provenance_actor_note":
                                        {
                                            "title": "Note",
                                            "type": "string"
                                        }
                                    }
                                }
                            }
                        }
                    }
                },
                "object_datasets":
                {
                    "title": "Related Datasets",
                    "description": "Links to related publications, datasets or catalogue entries (e.g. ARIADNE Portal).",
                    "type": "array",
                    "items":
                    {
                        "type": "object",
                        "required":
                        [
                            "dataset_uri"
                        ],
                        "properties":
                        {
                            "dataset_uri":
                            {
                                "title": "URI",
                                "type":
                                [
                                    "string",
                                    "null"
                                ],
                                "format": "uri",
                                "examples":
                                [
                                    "https://ariadne-infrastructure.eu/aocat/Resource/14EBE8A4-42D0-3FD2-AD07-4CFC6033E772"
                                ]
                            },
                            "dataset_label":
                            {
                                "title": "Label",
                                "description": "Title or name of the external dataset.",
                                "type": "string"
                            }
                        }
                    }
                }
            }
        }
    }
}
