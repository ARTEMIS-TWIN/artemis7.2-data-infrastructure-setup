{
    "$schema": "https://json-schema.org/draft/2020-12/schema",
    "$id": "https://vast-lab.org/artemis/schema/digital-service-form",
    "title": "ARTEMIS Digital Service — Data Collection Form",
    "description": "Data collection schema for digital services in the ARTEMIS project.",
    "type": "object",
    "required": [
        "service_id",
        "title",
        "service_type",
        "provided_by"
    ],
    "properties": {
        "service_id": {
            "title": "Service ID",
            "description": "Unique persistent identifier for the service instance (e.g. a URI or a local slug).",
            "type": "string",
            "examples": [
                "https://vast-lab.org/artemis/services/001",
                "artemis-service-001"
            ]
        },
        "title": {
            "title": "Service Title",
            "description": "The official name or title of the digital service.",
            "type": "string",
            "examples": [
                "ARTEMIS Conservation Scenario Simulator"
            ]
        },
        "service_type": {
            "title": "Service Type / Category",
            "description": "The functional or technical category of the service (e.g. 'Data Analysis', 'Environmental Monitoring', 'Simulation', 'Storage').",
            "type": "string",
            "examples": [
                "Data Analysis",
                "Simulation",
                "Environmental Monitoring"
            ]
        },
        "version": {
            "title": "Version",
            "description": "Version identifier of the service (e.g. '1.0.0', '2.3-beta').",
            "type": "string",
            "examples": [
                "1.0.0",
                "2.3-beta"
            ]
        },
        "description": {
            "title": "Description / Notes",
            "description": "Free-text description or notes about the service, its purpose, and relevant technical details.",
            "type": "string"
        },
        "provided_by": {
            "title": "Provided By (Actor)",
            "description": "The agent responsible for providing and maintaining the service.",
            "type": "object",
            "required": [
                "agent_type",
                "name"
            ],
            "properties": {
                "agent_type": {
                    "title": "Agent Type",
                    "description": "Whether the agent is an individual person or a group/organisation.",
                    "type": "string",
                    "enum": [
                        "Person",
                        "Group"
                    ]
                },
                "identifier": {
                    "title": "Agent Identifier",
                    "description": "A persistent identifier for the agent (e.g. ORCID, ROR, ISNI).",
                    "type": "string",
                    "examples": [
                        "https://orcid.org/0000-0000-0000-0000",
                        "https://ror.org/04390r489"
                    ]
                },
                "name": {
                    "title": "Name",
                    "description": "Full name of the person or official name of the group/organisation.",
                    "type": "string",
                    "examples": [
                        "PIN – Università di Firenze",
                        "Franco Niccolucci"
                    ]
                },
                "email": {
                    "title": "Email",
                    "type": "string",
                    "format": "email",
                    "examples": [
                        "contact@artemis-project.eu"
                    ]
                },
                "homepage": {
                    "title": "Homepage",
                    "description": "URL of the agent's website.",
                    "type": "string",
                    "format": "uri",
                    "examples": [
                        "https://www.vast-lab.org"
                    ]
                },
                "institution": {
                    "title": "Institution",
                    "description": "The institution or organisation the person is affiliated with. Applicable only when agent_type is 'Person'.",
                    "type": "string",
                    "examples": [
                        "PIN – Università di Firenze"
                    ]
                }
            }
        },
        "access_points": {
            "title": "Access Points",
            "description": "List of URLs or endpoints through which the service is accessible.",
            "type": "array",
            "minItems": 1,
            "items": {
                "type": "object",
                "required": [
                    "url"
                ],
                "properties": {
                    "url": {
                        "title": "Endpoint URL",
                        "type": "string",
                        "format": "uri",
                        "examples": [
                            "https://api.artemis-project.eu/simulator/v1"
                        ]
                    },
                    "endpoint_type": {
                        "title": "Endpoint Type",
                        "type": "string",
                        "enum": [
                            "REST API",
                            "GraphQL",
                            "SPARQL",
                            "Web UI",
                            "OGC Service",
                            "Other"
                        ]
                    },
                    "endpoint_methods": {
                        "title": "Endpoint Methods",
                        "description": "HTTP methods supported by this endpoint.",
                        "type": "array",
                        "items": {
                            "type": "string",
                            "enum": [
                                "GET",
                                "POST",
                                "PUT",
                                "PATCH",
                                "DELETE",
                                "HEAD",
                                "OPTIONS"
                            ]
                        },
                        "examples": [
                            [
                                "GET",
                                "POST"
                            ],
                            [
                                "GET",
                                "POST",
                                "PUT"
                            ]
                        ]
                    },
                    "notes": {
                        "title": "Notes on this endpoint",
                        "type": "string"
                    }
                }
            }
        },
        "intended_for": {
            "title": "Intended For (Audience / Purpose)",
            "description": "The target audience or intended use case of the service.",
            "type": "array",
            "items": {
                "type": "string"
            },
            "examples": [
                [
                    "Conservation Scientists",
                    "Heritage Data Curators"
                ]
            ]
        },
        "used_for": {
            "title": "Actually Used For (Operational History)",
            "description": "Activities or workflows in which this service has actually been deployed within ARTEMIS, which may differ from its original intended purpose.",
            "type": "array",
            "items": {
                "type": "object",
                "required": [
                    "activity_label"
                ],
                "properties": {
                    "activity_label": {
                        "title": "Activity Name",
                        "type": "string",
                        "examples": [
                            "MA-XRF Analysis Workflow — Raphael Portrait of Leo X"
                        ]
                    }
                }
            }
        },
        "used_physical_object_of_type": {
            "title": "Used Physical Object of Type",
            "description": "Types of physical objects or devices (e.g. sensors, instruments, hardware) used by or required for the operation of the service.",
            "type": "array",
            "items": {
                "type": "string"
            },
            "examples": [
                [
                    "MA-XRF Scanner",
                    "Environmental Sensor"
                ]
            ]
        },
        "has_functionality": {
            "title": "Has Functionality",
            "description": "Functionality of the service, expressed in some vocabulary.",
            "type": "array",
            "items": {
                "type": "string"
            }
        },
        "composed_of": {
            "title": "Sub-services",
            "description": "Titles of other services that compose this service (for composite or orchestrated services), and their URI if available.",
            "type": "array",
            "items": {
                "type": "object",
                "required": [
                    "sub_service_title"
                ],
                "properties": {
                    "sub_service_title": {
                        "title": "Sub-service Title",
                        "type": "string"
                    },
                    "sub_service_uri": {
                        "title": "Sub-service URI",
                        "description": "Persistent identifier (URI) of the sub-service, if available.",
                        "type": "string",
                        "format": "uri",
                        "examples": [
                            "https://vast-lab.org/artemis/services/spectral-preprocessing"
                        ]
                    }
                }
            }
        },
        "supported_language": {
            "title": "Supported Languages",
            "description": "Languages supported by the service interface, documentation, or textual input/output (ISO 639-2 codes recommended).",
            "type": "array",
            "items": {
                "type": "string"
            },
            "examples": [
                [
                    "eng"
                ],
                [
                    "eng",
                    "ita"
                ]
            ]
        },
        "media_type_consumed": {
            "title": "Media Types Consumed",
            "description": "Logical or standard media types accepted as input (e.g. 'RDF/Turtle', 'IIIF Manifest', 'GeoJSON').",
            "type": "array",
            "items": {
                "type": "string"
            },
            "examples": [
                [
                    "RDF/Turtle",
                    "GeoJSON"
                ]
            ]
        },
        "media_type_produced": {
            "title": "Media Types Produced",
            "description": "Logical or standard media types produced as output by the service.",
            "type": "array",
            "items": {
                "type": "string"
            },
            "examples": [
                [
                    "RDF/Turtle",
                    "IIIF Manifest"
                ]
            ]
        },
        "format_consumed": {
            "title": "Formats Consumed",
            "description": "MIME media types accepted as input by the service (e.g. 'application/json', 'image/tiff').",
            "type": "array",
            "items": {
                "type": "string"
            },
            "examples": [
                [
                    "application/json",
                    "image/tiff"
                ]
            ]
        },
        "format_produced": {
            "title": "Formats Produced",
            "description": "MIME media types generated by the service as output.",
            "type": "array",
            "items": {
                "type": "string"
            },
            "examples": [
                [
                    "application/json",
                    "application/ld+json"
                ]
            ]
        },
        "support_contact": {
            "title": "Technical Support Contact",
            "description": "Agent responsible for technical support and maintenance of the service.",
            "type": "object",
            "required": [
                "support_agent_type",
                "support_agent_name"
            ],
            "properties": {
                "support_agent_type": {
                    "title": "Support Agent Type",
                    "type": "string",
                    "enum": [
                        "Person",
                        "Group"
                    ]
                },
                "support_agent_identifier": {
                    "title": "Support Agent Identifier",
                    "type": "string"
                },
                "support_agent_name": {
                    "title": "Support Agent Name",
                    "type": "string"
                },
                "support_agent_email": {
                    "title": "Support Agent Email",
                    "type": "string",
                    "format": "email"
                },
                "support_agent_homepage": {
                    "title": "Support Agent Homepage",
                    "type": "string",
                    "format": "uri"
                },
                "support_agent_institution": {
                    "title": "Support Agent Institution",
                    "type": "string"
                }
            }
        },
        "documentation": {
            "title": "Documentation",
            "description": "References to documents describing the service (technical specs, user manuals, papers).",
            "type": "array",
            "items": {
                "type": "object",
                "required": [
                    "doc_description"
                ],
                "properties": {
                    "doc_description": {
                        "title": "Document Description",
                        "description": "Title, author, year.",
                        "type": "string",
                        "examples": [
                            "ARTEMIS Service Technical Specification v1.0; Niccolucci, F.; Felicetti, A.; 2024"
                        ]
                    },
                    "doc_url": {
                        "title": "Accessible At",
                        "description": "URL where the document can be accessed.",
                        "type": "string",
                        "format": "uri",
                        "examples": [
                            "https://doi.org/10.1234/example"
                        ]
                    },
                    "doc_type": {
                        "title": "Document Type",
                        "type": "string",
                        "enum": [
                            "Technical Specification",
                            "User Manual",
                            "API Reference",
                            "Scientific Paper",
                            "Other"
                        ]
                    }
                }
            }
        }
    }
}