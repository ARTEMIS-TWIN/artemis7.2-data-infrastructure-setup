<?xml version="1.0" encoding="UTF-8"?>
<rdf:RDF xmlns:rhdto="http://vast-lab.org/rhdto/"
    xmlns:rdf="http://www.w3.org/1999/02/22-rdf-syntax-ns#"
    xmlns:rdfs="http://www.w3.org/2000/01/rdf-schema#"
    xmlns:owl="http://www.w3.org/2002/07/owl#"
    xmlns:crm="http://www.cidoc-crm.org/cidoc-crm/"
    xmlns:crmdig="http://www.cidoc-crm.org/extensions/crmdig/"
    xmlns:crmsci="http://www.cidoc-crm.org/extensions/crmsci/"
    xmlns:aocat="https://www.ariadne-infrastructure.eu/resource/ao/cat/1.1/"
    xmlns:nont="https://dlnarratives.eu/ontology#">

